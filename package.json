{
    "name": "minki-blog",
    "title": "Minki's Blog",
    "author": "Minki <atunh9988@naver.com>",
    "version": "1.8.2",
    "homepage": "https://minkithub.github.io/",
    "repository": {
        "type": "git",
        "url": "https://github.com/minkithub/minkithub.github.io"
    },
    "bugs": "https://github.com/Huxpro/huxpro.github.io/issues",
    "devDependencies": {
        "chokidar-cli": "^3.0.0",
        "concurrently": "^9.2.1",
        "less": "^4.6.4",
        "less-plugin-clean-css": "^1.6.0",
        "terser": "^5.46.1"
    },
    "scripts": {
        "build:css": "node scripts/build-css.mjs",
        "build:js": "node scripts/build-js.mjs",
        "build": "npm run build:js && npm run build:css",
        "check": "npm run build && bundle exec jekyll build",
        "watch:css": "chokidar \"less/*.less\" -c \"npm run build:css\" --polling --interval 300",
        "watch:js": "chokidar \"js/hux-blog.js\" -c \"npm run build:js\" --polling --interval 300",
        "watch:assets": "concurrently -k -n css,js \"npm run watch:css\" \"npm run watch:js\"",
        "start": "bundle exec jekyll serve -w --host 0.0.0.0 --port ${JEKYLL_PORT:-4000}",
        "dev": "npm run build && concurrently -k -n assets,jekyll \"npm run watch:assets\" \"npm run start\"",
        "boil": "git push boilerplate boilerplate:master",
        "push": "git push origin master --tag"
    }
}
